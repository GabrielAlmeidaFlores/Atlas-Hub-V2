# Backend environment variables
# Copy to .env.local for local development

STAGE=dev

# DynamoDB table names (auto-computed from stage in serverless.yml)
INCORPORADORAS_TABLE=AtlasIncorporadoras-dev
ADMINS_TABLE=AtlasAdmins-dev
PROJETOS_TABLE=AtlasProjetos-dev
SCORECARD_TABLE=AtlasScorecard-dev
NOTIFICACOES_TABLE=AtlasNotificacoes-dev
AUDITORIA_TABLE=AtlasAuditoria-dev
NOTAS_TABLE=AtlasNotas-dev

# S3
DOCUMENTS_BUCKET=atlas-hub-documents-dev

# Cognito pool IDs (output from serverless deploy)
USER_POOL_ID=sa-east-1_XXXXXXXXX
USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# SES
SES_FROM_EMAIL=noreply@atlashub.com.br

# CORS
CORS_ORIGINS=*
